{
  "name": "stockpulse",
  "version": "1.0.0",
  "description": "StockPulse — system analizy sentymentu rynku akcji healthcare",
  "private": true,
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "node node_modules/typescript/bin/tsc -p tsconfig.build.json && node dist/main.js",
    "start:prod": "node dist/main.js",
    "test": "jest",
    "test:agents": "jest --testPathPattern=test/agents/",
    "test:agent:sentiment": "jest test/agents/sentiment-agent.spec.ts",
    "test:agent:alerts": "jest test/agents/alert-evaluator-agent.spec.ts",
    "test:agent:correlation": "jest test/agents/correlation-agent.spec.ts",
    "test:agent:sec": "jest test/agents/sec-filings-agent.spec.ts",
    "test:agent:price": "jest test/agents/price-outcome-agent.spec.ts",
    "test:agent:collectors": "jest test/agents/collectors-agent.spec.ts",
    "test:e2e": "jest --config test/jest-e2e.json",
    "test:all": "node scripts/test-all.js",
    "test:reddit": "node scripts/test-reddit.js",
    "test:finnhub": "node scripts/test-finnhub.js",
    "test:edgar": "node scripts/test-sec-edgar.js",
    "test:stocktwits": "node scripts/test-stocktwits.js",
    "test:telegram": "node scripts/test-telegram.js",
    "seed": "node node_modules/typescript/bin/tsc -p tsconfig.build.json && node dist/database/seeds/seed.js",
    "backfill:sentiment": "node node_modules/typescript/bin/tsc -p tsconfig.build.json && node dist/database/seeds/backfill-sentiment.js"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/event-emitter": "^2.1.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/typeorm": "^10.0.0",
    "bullmq": "^5.13.0",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.0",
    "fast-xml-parser": "^5.4.1",
    "ioredis": "^5.4.0",
    "joi": "^17.13.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.0",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  }
}
