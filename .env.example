# ═══════════════════════════════════════════════════════
# StockPulse — Environment Variables
# Skopiuj ten plik jako .env i uzupełnij wartości
# cp .env.example .env
# ═══════════════════════════════════════════════════════

# ── REDDIT API (FREE) ──────────────────────────────────
# 1. Idź na: https://www.reddit.com/prefs/apps
# 2. Kliknij "create another app..." na dole
# 3. Typ: "script" (dla personal use / bota)
# 4. Name: StockPulse
# 5. Redirect URI: http://localhost:3000/callback
# 6. Po utworzeniu: client_id jest pod nazwą apki, secret obok
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=twoj_reddit_username
REDDIT_PASSWORD=twoje_reddit_haslo
REDDIT_USER_AGENT=StockPulse/1.0 (by /u/twoj_reddit_username)

# ── FINNHUB API (FREE — 60 req/min) ───────────────────
# 1. Idź na: https://finnhub.io/register
# 2. Zarejestruj się (email + hasło)
# 3. API Key jest na dashboardzie po zalogowaniu
# Free tier: 60 calls/min, real-time US stocks, news, fundamentals
FINNHUB_API_KEY=d4qsno9r01qrphabs1d0d4qsno9r01qrphabs1dg

# ── SEC EDGAR (FREE — 10 req/sec) ─────────────────────
# Nie wymaga rejestracji ani klucza!
# SEC wymaga TYLKO poprawnego User-Agent z Twoim emailem
# Format: "CompanyName AdminEmail"
# Docs: https://www.sec.gov/os/webmaster-faq#developers
SEC_USER_AGENT=StockPulse przemek@twojmail.com

# ── ANTHROPIC / CLAUDE API (PAID — ~$0.25/1M input tokens Haiku) ──
# 1. Idź na: https://console.anthropic.com/
# 2. Zarejestruj się i dodaj billing
# 3. Wygeneruj API Key w Settings > API Keys
# Używamy Claude Haiku — najtańszy model, ~$50-150/msc
ANTHROPIC_API_KEY=

# ── TELEGRAM BOT (FREE) ───────────────────────────────
# 1. Otwórz Telegram i napisz do @BotFather
# 2. Wyślij: /newbot
# 3. Podaj nazwę (np. StockPulse Alerts)
# 4. Podaj username (np. stockpulse_alerts_bot)
# 5. BotFather da Ci token
# 6. Aby uzyskać CHAT_ID:
#    a) Napisz cokolwiek do swojego bota
#    b) Otwórz: https://api.telegram.org/bot<TWOJ_TOKEN>/getUpdates
#    c) Znajdź "chat":{"id": XXXXXXX} — to Twój CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── STOCKTWITS (ZAMKNIĘTE — backup plan) ──────────────
# StockTwits API jest ZAMKNIĘTE dla nowych rejestracji!
# Alternatywa: scraping publicznych endpointów lub RapidAPI
# https://api.stocktwits.com/api/2/streams/symbol/AAPL.json (public, no auth)
# Limit: 200 req/hour bez tokena
STOCKTWITS_ACCESS_TOKEN=

# ── BAZY DANYCH (Docker Compose) ─────────────────────────
# Te zmienne są używane zarówno przez docker-compose.yml
# jak i przez aplikację Node.js do łączenia się z bazami.
# Uruchom: docker compose up -d
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stockpulse
POSTGRES_USER=stockpulse
POSTGRES_PASSWORD=stockpulse_dev_2026

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── FINBERT SIDECAR ───────────────────────────────────
# URL serwisu FinBERT (w Docker: http://finbert:8000, lokalnie: http://localhost:8000)
FINBERT_SIDECAR_URL=http://localhost:8000
# Model HuggingFace (domyślnie ProsusAI/finbert)
FINBERT_MODEL_NAME=ProsusAI/finbert
# Max tekstów w batch (laptop: 8, RTX 6000 Ada: 64)
FINBERT_BATCH_SIZE=16
# Max tokenów per tekst
FINBERT_MAX_TOKEN_LENGTH=512
# Dockerfile: Dockerfile (GPU/CUDA) lub Dockerfile.cpu (CPU-only)
FINBERT_DOCKERFILE=Dockerfile

# ── APP CONFIG ─────────────────────────────────────────
NODE_ENV=development
PORT=3000
